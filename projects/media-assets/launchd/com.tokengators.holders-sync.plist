<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.tokengators.holders-sync</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/operator/repos/MainFrame/projects/media-assets/scripts/sync-pipeline.sh</string>
        <string>--fast</string>
    </array>

    <!-- Fast loop every 60s. launchd won't double-fire while a run is in flight. -->
    <key>StartInterval</key>
    <integer>60</integer>

    <key>RunAtLoad</key>
    <true/>

    <!-- Ensure homebrew python3 (web3 module) is found. -->
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    </dict>

    <key>StandardOutPath</key>
    <string>/Users/operator/.openclaw/logs/holders-sync-launchd.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/operator/.openclaw/logs/holders-sync-launchd.log</string>

    <!-- 5 min max per tick; a tick usually finishes in <15s. -->
    <key>TimeOut</key>
    <integer>300</integer>

    <!-- Throttle relaunch on crash loop. -->
    <key>ThrottleInterval</key>
    <integer>60</integer>
</dict>
</plist>
